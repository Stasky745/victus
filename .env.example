# Copy this file to .env and fill in real values. Never commit .env.

### Postgres (only used if DB_DRIVER=postgres — builds DATABASE_URL for the app
# container in docker-compose.yml; ignored by docker-compose.sqlite.yml)
POSTGRES_PASSWORD=

### HTTP
HTTP_ADDR=:8080
# Public URL Victus is served at — used to build the OIDC redirect URL and to
# decide whether cookies get the Secure flag when TRUST_PROXY_HEADERS is unset.
BASE_URL=https://victus.example.com
# Set to true only if Victus sits behind a reverse proxy you control (Caddy/Traefik/nginx)
# that terminates TLS and can be trusted to set X-Forwarded-* headers correctly.
TRUST_PROXY_HEADERS=false

### Database (for local `go run` without docker-compose; docker-compose.yml /
# docker-compose.sqlite.yml both set DB_DRIVER/DATABASE_URL themselves, overriding this)
# "sqlite" (default) or "postgres". SQLite needs no separate database service —
# good for small/single-user installs; Postgres scales better for multi-user ones.
DB_DRIVER=sqlite
# SQLite: a file path (e.g. /data/victus.db). Postgres: a full connection DSN,
# e.g. postgres://victus:changeme@localhost:5432/victus?sslmode=disable
DATABASE_URL=./victus.db

### Auth. "password" (the default) is Victus's own built-in login — no
# external dependency needed. Set to "oidc" to delegate entirely to an
# external IdP (Pocket ID, Authentik, Keycloak, Authelia, ...) instead;
# local password login is disabled in that mode.
AUTH_MODE=password

# Generate with: openssl rand -base64 32
SESSION_SECRET=

## password mode only — bootstraps the first (admin) account on startup.
# Idempotent: safe to leave set across restarts. Additional users are added
# from Settings by an admin once logged in.
ADMIN_EMAIL=
ADMIN_PASSWORD=

## oidc mode only
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=https://victus.example.com/auth/callback
# Comma-separated allowlist of emails permitted to auto-provision an account on first login.
# Leave empty to allow anyone who can authenticate against your OIDC provider.
ADMIN_ALLOWED_EMAILS=

# Meal importers — both optional. Leave MEALIE_BASE_URL empty to hide the
# Mealie import section entirely; Open Food Facts needs no config (public
# API, no auth). Tandoor import isn't implemented yet (planned for later).
MEALIE_BASE_URL=
# A long-lived API token generated in Mealie's UI (Settings > API Tokens).
MEALIE_API_KEY=

LOG_LEVEL=info
